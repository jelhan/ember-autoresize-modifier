{
  "name": "ember-autoresize-modifier",
  "version": "0.8.0",
  "description": "Autoresize Element Modifier for Ember.js",
  "keywords": [
    "ember-addon"
  ],
  "repository": "https://github.com/jelhan/ember-autoresize-modifier",
  "license": "MIT",
  "author": "Jeldrik Hanschke",
  "scripts": {
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "lint:css": "stylelint \"**/*.css\" --allow-empty-input",
    "lint:css:fix": "concurrently \"pnpm:lint:css -- --fix\"",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" --prefixColors auto",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix"
  },
  "dependencies": {
    "@babel/core": "^7.26.7",
    "ember-auto-import": "^2.10.0",
    "ember-cli-babel": "^8.2.0",
    "ember-cli-htmlbars": "^7.0.0",
    "ember-modifier": "^3.0.0 || ^4.0.0"
  },
  "devDependencies": {
    "@babel/eslint-parser": "7.28.6",
    "@babel/plugin-proposal-decorators": "7.29.0",
    "@eslint/js": "9.39.4",
    "@release-it-plugins/lerna-changelog": "8.0.1",
    "concurrently": "9.2.1",
    "ember-template-lint": "7.9.3",
    "ember-template-lint-plugin-prettier": "5.0.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-ember": "12.7.5",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "16.5.0",
    "prettier": "3.8.1",
    "prettier-plugin-ember-template-tag": "2.1.3",
    "release-it": "17.11.0",
    "stylelint": "16.26.1",
    "stylelint-config-standard": "40.0.0",
    "stylelint-prettier": "5.0.3"
  },
  "peerDependencies": {
    "ember-source": ">=4.12.0"
  },
  "engines": {
    "node": "18.* || >= 20"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {},
  "release-it": {
    "plugins": {
      "@release-it-plugins/lerna-changelog": {
        "infile": "CHANGELOG.md"
      }
    },
    "git": {
      "tagName": "v${version}"
    },
    "github": {
      "release": true,
      "tokenRef": "GITHUB_AUTH"
    }
  }
}
